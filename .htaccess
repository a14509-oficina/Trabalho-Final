Options -Indexes
ServerSignature Off

<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^config/ - [F,L]
  RewriteRule ^classes/ - [F,L]
  RewriteRule ^setup/ - [F,L]
  RewriteRule ^script\.sql$ - [F,L]
</IfModule>
